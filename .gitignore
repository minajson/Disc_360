# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-test/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local development artifacts
/.contact-inbox.jsonl

# playwright
/test-results/
/playwright-report/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# the template is authoritative documentation — no real values in it
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Legacy JSON mock store — removed; never reintroduce.
.mockdb/

# Raw media masters (processed outputs in public/ are committed; regenerate
# via scripts/process-media.mjs). The brand mark master IS committed.
/assets-src/media/
/assets-src/brand/mark.png
/.playwright-mcp/
