# ── DISC360 environment ─────────────────────────────────────────────
# Copy to .env.local. Never commit real values.

# ── Supabase ────────────────────────────────────────────────────────
# Local development: `npx supabase start` prints these values.
# Production: from your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used exclusively in server actions/route handlers where an RLS
# bypass is explicitly justified in a comment.
SUPABASE_SERVICE_ROLE_KEY=

# ── Public base URL ─────────────────────────────────────────────────
# Used for metadata, emails, share links and QR codes.
# NEXT_PUBLIC_SITE_URL is frozen into the bundle at build time; SITE_URL is read
# at runtime on the server and takes precedence, so one build can serve several
# hosts (preview, tunnel, production).
NEXT_PUBLIC_SITE_URL=
SITE_URL=

# ── OAuth providers ─────────────────────────────────────────────────
# Optional: email/password works without these. When a provider's variables are
# absent the app disables that button and says so explicitly, rather than
# handing the user to a broken provider error page.
#
# These names are read by BOTH supabase/config.toml (local Auth container) and
# the Next.js server (to decide whether to offer the button). The previous
# SUPABASE_AUTH_* names were read by nothing at all.
#
# Full setup instructions: docs/OAUTH_SETUP.md

# Google Cloud → APIs & Services → Credentials → OAuth client ID (Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID → App registrations
# AZURE_TENANT_URL selects the supported account types, e.g.
#   https://login.microsoftonline.com/common        (personal + work/school)
#   https://login.microsoftonline.com/<tenant-id>   (single tenant)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_URL=

# ── Email (optional in development) ─────────────────────────────────
# Without a key, emails are logged to notification_logs instead of sent.
RESEND_API_KEY=
EMAIL_FROM="DISC360 <notifications@disc360.app>"
