# ── DISC360 environment ─────────────────────────────────────────────
# Copy to .env.local. Never commit real values.

# Public site URL (used for metadata, emails, QR codes).
# NEXT_PUBLIC_SITE_URL is frozen into the bundle at build time; set the
# optional SITE_URL on the server process to override it at runtime
# (e.g. one image deployed to several hosts, or the Playwright test server).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# SITE_URL=

# ── Supabase ────────────────────────────────────────────────────────
# Local development: `npx supabase start` prints these values.
# Production: from your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used exclusively in server actions/route handlers.
SUPABASE_SERVICE_ROLE_KEY=

# ── OAuth providers (optional — email/password works without these) ─
# Configure in supabase/config.toml (local) or the Supabase dashboard
# (production). Google: https://console.cloud.google.com/apis/credentials
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
# Microsoft/Azure: https://portal.azure.com → App registrations
SUPABASE_AUTH_AZURE_CLIENT_ID=
SUPABASE_AUTH_AZURE_SECRET=

# ── Email (optional in development) ─────────────────────────────────
# Without a key, emails are logged to notification_logs instead of sent.
RESEND_API_KEY=
EMAIL_FROM="DISC360 <notifications@disc360.app>"
